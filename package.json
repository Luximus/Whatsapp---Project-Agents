{
  "name": "luxisoft-whatsapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:agent": "tsx scripts/agent-test/run.ts",
    "test:agent:case": "tsx scripts/agent-test/run.ts --case",
    "test:agent:nofix": "tsx scripts/agent-test/run.ts --no-fix",
    "test:agent:llm": "tsx scripts/agent-test/run.ts --llm",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "db:apply": "tsx scripts/db-apply.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@openai/agents": "^0.8.1",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "dotenv": "^17.2.1",
    "fastify": "^5.6.0",
    "fastify-plugin": "^5.0.1",
    "firebase-admin": "^13.5.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.18.0",
    "pg": "^8.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.2.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
