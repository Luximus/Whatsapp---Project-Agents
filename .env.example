# -----------------------------
# Server
# -----------------------------
PORT=4010
HOST=0.0.0.0
LOG_LEVEL=info

# -----------------------------
# Legacy SQL (solo endpoints legacy)
# El flujo bridge OTP por webhook no guarda sesiones en BD.
# -----------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/whatsapp

# CSV list. Example: http://localhost:3000,https://app.example.com
CORS_ORIGIN=http://localhost:3000,http://localhost:8081

# -----------------------------
# Firebase Admin (solo para endpoints protegidos legacy)
# use una opcion
# -----------------------------
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=

# -----------------------------
# WhatsApp Cloud API
# -----------------------------
WHATSAPP_VERIFY_NUMBER_E164=+573001112233
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# -----------------------------
# Project resolution
# -----------------------------
WHATSAPP_DEFAULT_PROJECT=luxisoft

# Legacy / compat (no usado por bridge webhook mode)
PROJECT_DATABASES_JSON={}

# -----------------------------
# Agents
# -----------------------------
AGENTS_DIR=./agents
ORCHESTRATOR_AGENT_DIR=./agents/orchestrator
# Fuentes extra por proyecto (URL o paths locales).
# Ejemplo:
# {"luxisoft":["https://luxisoft.com"],"navai":["https://navai.luxisoft.com"],"luxichat":["/var/www/luxichat"]}
AGENT_PROJECT_SOURCES_JSON={"luxisoft":["https://luxisoft.com"],"navai":["https://navai.luxisoft.com"],"luxichat":["/var/www/luxichat"]}
# Numero que recibe notificacion para transferencia a agente humano.
AGENT_HUMAN_TRANSFER_NUMBER_E164=

# -----------------------------
# OpenAI Agents
# -----------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORCHESTRATOR_MODEL=gpt-5.4-mini
OPENAI_PROJECT_MODEL=gpt-5.4-mini
OPENAI_AGENT_MAX_TOOL_STEPS=6

# -----------------------------
# Bridge projects (auth + callback per project)
# -----------------------------
# JSON object.
# Example:
# {"luxichat":{"api_key":"change_me_luxichat","callback_url":"https://api.luxichat.com/api/integrations/whatsapp/bridge","callback_secret":"change_me_cb_1"},"navai":{"api_key":"change_me_navai","callback_url":"https://api.navai.com/api/integrations/whatsapp/bridge","callback_secret":"change_me_cb_2"}}
BRIDGE_PROJECTS_JSON={"luxichat":{"api_key":"change_me_luxichat","callback_url":"https://api.luxichat.com/api/integrations/whatsapp/bridge","callback_secret":"change_me_cb_1"},"navai":{"api_key":"change_me_navai","callback_url":"https://api.navai.com/api/integrations/whatsapp/bridge","callback_secret":"change_me_cb_2"},"luxisoft":{"api_key":"change_me_luxisoft","callback_url":"https://api.luxisoft.com/api/integrations/whatsapp/bridge","callback_secret":"change_me_cb_3"}}

# OTP/session behavior
BRIDGE_OTP_TTL_SECONDS=300
BRIDGE_OTP_MAX_ATTEMPTS=5

# Callback delivery behavior
BRIDGE_CALLBACK_TIMEOUT_MS=7000
BRIDGE_EVENT_MAX_RETRIES=6
BRIDGE_EVENT_RETRY_BASE_SECONDS=20
BRIDGE_EVENT_DISPATCH_LIMIT=50

# Optional token for manual/cron dispatch endpoint (/api/bridge/events/dispatch)
BRIDGE_DISPATCH_TOKEN=
